# ── Base de datos ──────────────────────────────────────────────────────────────
# Contraseña para el contenedor de PostgreSQL
# Generar con: openssl rand -base64 24
DB_PASSWORD=cambia-esta-contrasena-en-produccion

# ── JWT ────────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Generar con: openssl rand -hex 32
JWT_SECRET=cambia-este-secreto-minimo-32-chars-requerido-aqui
JWT_REFRESH_SECRET=cambia-este-refresh-secreto-minimo-32-chars-requerido

JWT_ACCESS_EXPIRY=4h
JWT_REFRESH_EXPIRY=7d

# ── Servidor ───────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Residencia Éclat <noreply@residencia-eclat.com>

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
