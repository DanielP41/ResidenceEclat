# Database (puerto 5434 mapeado en docker-compose.yml)
DATABASE_URL="postgresql://residencia:your-db-password@localhost:5434/residencia_eclat?schema=public"

# JWT — mínimo 32 caracteres cada uno (usar: openssl rand -hex 32)
JWT_SECRET="genera-con-openssl-rand-hex-32-minimo-32-chars-requerido"
JWT_REFRESH_SECRET="genera-con-openssl-rand-hex-32-minimo-32-chars-requerido"
JWT_ACCESS_EXPIRY="4h"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="Residencia Éclat <noreply@residencia-eclat.com>"

# Cloudinary (placeholder — configure when ready)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
