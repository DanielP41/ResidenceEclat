generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// Users — Staff y Admin del sistema
// ──────────────────────────────────────────
model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique @db.VarChar(100)
  password   String   @db.VarChar(255)
  role       Role     @default(STAFF)
  name       String   @db.VarChar(100)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  auditLogs     AuditLog[]
  deletedRooms  Room[]    @relation("DeletedByUser")
  cancelledBookings Booking[] @relation("CancelledByUser")

  @@map("users")
}

enum Role {
  ADMIN
  STAFF
}

// ──────────────────────────────────────────
// Rooms — Habitaciones de la residencia
// ──────────────────────────────────────────
model Room {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  capacity    Int
  residence   String   @default("Residencia A") @db.VarChar(50)
  amenities   Json?    @default("[]")
  images      Json?    @default("[]")
  isActive    Boolean  @default(true) @map("is_active")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()
  deletedById Int?     @map("deleted_by")
  deletedBy   User?    @relation("DeletedByUser", fields: [deletedById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  bookings Booking[]

  @@map("rooms")
}

// ──────────────────────────────────────────
// Guests — Huéspedes
// ──────────────────────────────────────────
model Guest {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(100)
  email          String   @unique @db.VarChar(100)
  phone          String?  @db.VarChar(20)
  documentType   String?  @map("document_type") @db.VarChar(20)
  documentNumber String?  @map("document_number") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  bookings Booking[]

  @@map("guests")
}

// ──────────────────────────────────────────
// Bookings — Reservas
// ──────────────────────────────────────────
model Booking {
  id                Int      @id @default(autoincrement())
  roomId            Int      @map("room_id")
  room              Room     @relation(fields: [roomId], references: [id])
  guestId           Int      @map("guest_id")
  guest             Guest    @relation(fields: [guestId], references: [id])
  checkIn           DateTime @map("check_in") @db.Date
  checkOut          DateTime @map("check_out") @db.Date
  checkedInAt       DateTime? @map("checked_in_at") @db.Timestamptz()
  checkedOutAt      DateTime? @map("checked_out_at") @db.Timestamptz()
  totalNights       Int      @map("total_nights")
  totalPrice        Decimal  @map("total_price") @db.Decimal(10, 2)
  status            BookingStatus @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING) @map("payment_status")
  acceptedTerms     Boolean  @default(false) @map("accepted_terms")
  cancellationReason String? @map("cancellation_reason") @db.Text
  cancelledAt       DateTime? @map("cancelled_at") @db.Timestamptz()
  cancelledById     Int?     @map("cancelled_by")
  cancelledBy       User?    @relation("CancelledByUser", fields: [cancelledById], references: [id])
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  PARTIAL
}

// ──────────────────────────────────────────
// AuditLog — Trazabilidad
// ──────────────────────────────────────────
model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  user       User?    @relation(fields: [userId], references: [id])
  action     String   @db.VarChar(50)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   Int      @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("audit_logs")
}

// ──────────────────────────────────────────
// Observations — Notas internas por sede
// ──────────────────────────────────────────
model Observation {
  id        Int      @id @default(autoincrement())
  residence String   @unique @db.VarChar(10)
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("observations")
}
