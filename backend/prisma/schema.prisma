generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int        @id @default(autoincrement())
  email             String     @unique @db.VarChar(100)
  password          String     @db.VarChar(255)
  role              Role       @default(STAFF)
  name              String     @db.VarChar(100)
  isActive          Boolean    @default(true) @map("is_active")
  tokenVersion      Int        @default(0) @map("token_version")
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  auditLogs         AuditLog[]
  cancelledBookings Booking[]  @relation("CancelledByUser")
  deletedRooms      Room[]     @relation("DeletedByUser")

  @@map("users")
}

model Residence {
  id           Int          @id @default(autoincrement())
  name         String       @db.VarChar(100)
  address      String?      @db.VarChar(255)
  description  String?
  images       Json?        @default("[]")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  observations Observation?
  rooms        Room[]

  @@map("residences")
}


model Room {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(100)
  description String?
  price       Decimal    @db.Decimal(10, 2)
  capacity    Int
  status      RoomStatus @default(AVAILABLE)
  amenities   Json?      @default("[]")
  images      Json?      @default("[]")
  isActive    Boolean    @default(true) @map("is_active")
  isDeleted   Boolean    @default(false) @map("is_deleted")
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz(6)
  deletedById Int?       @map("deleted_by")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  residenceId Int        @map("residence_id")
  bookings    Booking[]
  deletedBy   User?      @relation("DeletedByUser", fields: [deletedById], references: [id])
  residence   Residence  @relation(fields: [residenceId], references: [id], onDelete: Cascade)

  @@index([residenceId])
  @@index([status])
  @@index([isDeleted])
  @@map("rooms")
}

model Guest {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(100)
  email          String    @unique @db.VarChar(100)
  phone          String?   @db.VarChar(20)
  documentType   String?   @map("document_type") @db.VarChar(20)
  documentNumber String?   @map("document_number") @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  bookings       Booking[]

  @@map("guests")
}

model Booking {
  id                 Int           @id @default(autoincrement())
  roomId             Int           @map("room_id")
  guestId            Int           @map("guest_id")
  checkIn            DateTime      @map("check_in") @db.Date
  checkOut           DateTime      @map("check_out") @db.Date
  checkedInAt        DateTime?     @map("checked_in_at") @db.Timestamptz(6)
  checkedOutAt       DateTime?     @map("checked_out_at") @db.Timestamptz(6)
  totalNights        Int           @map("total_nights")
  totalPrice         Decimal       @map("total_price") @db.Decimal(10, 2)
  status             BookingStatus @default(PENDING)
  paymentStatus      PaymentStatus @default(PENDING) @map("payment_status")
  acceptedTerms      Boolean       @default(false) @map("accepted_terms")
  cancellationReason String?       @map("cancellation_reason")
  cancelledAt        DateTime?     @map("cancelled_at") @db.Timestamptz(6)
  cancelledById      Int?          @map("cancelled_by")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  cancelledBy        User?         @relation("CancelledByUser", fields: [cancelledById], references: [id])
  guest              Guest         @relation(fields: [guestId], references: [id])
  room               Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([guestId])
  @@index([status])
  @@index([checkIn])
  @@index([checkOut])
  @@map("bookings")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  action     String   @db.VarChar(50)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   Int      @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([entityType])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Observation {
  id          Int       @id @default(autoincrement())
  content     String
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  residenceId Int       @unique @map("residence_id")
  residence   Residence @relation(fields: [residenceId], references: [id], onDelete: Cascade)


  @@map("observations")
}

enum Role {
  ADMIN
  STAFF
}

enum RoomStatus {
  AVAILABLE
  PARTIAL_1
  PARTIAL_2
  PARTIAL_3
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  PARTIAL
}
